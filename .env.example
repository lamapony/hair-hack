OPENAI_API_KEY=sk-...
# Image model: gpt-image-2 (recommended), gpt-image-1, gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Provider: openai (default) | hairgen (not implemented yet)
IMAGE_PROVIDER=openai

# Rate limiting (Phase 1 — wired on POST /api/generate)
RATE_LIMIT_PER_HOUR=10
# DAILY_GENERATION_CAP=100
# RATE_LIMIT_DISABLED=true

# Legal deploy gate (Phase 1 — optional)
# LEGAL_PAGES_REQUIRED=false

# DTC Stripe checkout (/try flow)
STRIPE_SECRET_KEY=sk_test_...
# Optional — checkout redirect URLs when not inferrable from request headers
# NEXT_PUBLIC_APP_URL=http://localhost:3000
