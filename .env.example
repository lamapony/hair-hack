OPENAI_API_KEY=sk-...
# Image model: gpt-image-2 (recommended), gpt-image-1, gpt-image-1.5
OPENAI_IMAGE_MODEL=gpt-image-2

# Provider: openai (default) | hairgen (spike — needs HAIRGEN_API_KEY)
IMAGE_PROVIDER=openai
# HAIRGEN_API_KEY=your_hairgen_key

# Rate limiting (POST /api/generate — per client IP)
RATE_LIMIT_PER_HOUR=10
# DAILY_GENERATION_CAP=100
# RATE_LIMIT_DISABLED=true

# Legal deploy gate (Phase 1 — optional)
# LEGAL_PAGES_REQUIRED=false
